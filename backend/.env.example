DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmforce
REDIS_URL=redis://localhost:6379
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890
TOMORROW_IO_API_KEY=your_tomorrow_io_api_key
JWT_SECRET_KEY=change-this-to-a-strong-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
FIREBASE_CONFIG_PATH=/path/to/firebase-service-account.json
PLATFORM_COMMISSION_RATE=0.075
APP_NAME=FarmForce AI
DEBUG=False
